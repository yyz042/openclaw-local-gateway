# 网关运行时参数（可选）。复制后按需调整：
#   cp env.example .env
# 启动：npm run start:env
#
# 模型、上游 URL、API Key 等请配置 router.config.json：
#   cp router.config.example.json router.config.json
# 热重载：curl -X POST http://127.0.0.1:38080/reload
# 配置路径覆盖：GATEWAY_CONFIG_PATH 或 ROUTER_CONFIG_PATH

GATEWAY_PORT=38080
# Set to 1 for local dry-run (no upstream call)
GATEWAY_DRY_RUN=0
# Duplicate request guard window
GATEWAY_DEDUP_WINDOW_MS=5000
# Session routing TTL (pinning / upgrade / three-strike escalation)
GATEWAY_SESSION_TTL_MS=1800000
# Long context governance: max messages (system/developer preserved; conversation tail kept)
GATEWAY_MAX_MESSAGES=60
# Trigger message compression when request body exceeds this size (KB)
GATEWAY_COMPRESSION_THRESHOLD_KB=180
# Optional request log path (default ./logs/gateway-requests.json)
# GATEWAY_REQUEST_LOG_FILE=./logs/gateway-requests.json
