# Copy to .env and fill secrets.
# Start with: npm run start:env

GATEWAY_PORT=38080
# Set to 1 for local dry-run (no upstream call)
GATEWAY_DRY_RUN=0
# Duplicate request guard window
GATEWAY_DEDUP_WINDOW_MS=5000
# Session routing TTL (pinning / upgrade / three-strike escalation)
GATEWAY_SESSION_TTL_MS=1800000

# SIMPLE -> your internal vLLM
VLLM_SIMPLE_BASE=http://127.0.0.1:8011/v1
VLLM_SIMPLE_MODEL=qwen3.5

# MEDIUM / COMPLEX / REASONING default target
VLLM_DEFAULT_BASE=https://api.us-west-2.modal.direct/v1
VLLM_DEFAULT_MODEL=zai-org/GLM-5.1-FP8
VLLM_DEFAULT_API_KEY=
